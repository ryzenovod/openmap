# Backend URL used by browser runtime
VITE_API_BASE_URL=http://localhost:8000

# Role header for backend access stub
VITE_API_ROLE=viewer

# Show backend status badge in UI (true/false)
VITE_DEBUG_MODE=false

# Local legacy raster tile URL template. Tile samples use .png:
# 18/227468/96187.png
VITE_LEGACY_TILE_URL=http://localhost:8081/tiles/{z}/{x}/{y}.png

# Fetch optional territorial GeoJSON overlay; empty FeatureCollection is handled without blocking the raster map
VITE_MAP_GEOMETRY_ENABLED=true
