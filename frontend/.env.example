# Backend URL used by browser runtime
VITE_API_BASE_URL=http://localhost:8000

# Role header for backend access stub
VITE_API_ROLE=viewer

# Show backend status badge in UI (true/false)
VITE_DEBUG_MODE=false

# Optional legacy tile URL template, e.g. http://localhost:8080/tiles/{z}/{x}/{y}.png
VITE_LEGACY_TILE_URL=

# Set true only when territorial geometry/GeoJSON is connected
VITE_MAP_GEOMETRY_ENABLED=false
